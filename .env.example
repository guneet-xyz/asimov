# === Required ===
ASSISTANT_NAME=Asimov
ONECLI_URL=http://localhost:10254

# === Channel credentials (at least one required) ===
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# DISCORD_BOT_TOKEN=...

# === LLM provider ===
# Custom API endpoint (e.g. LiteLLM proxy). Leave empty for api.anthropic.com.
# ANTHROPIC_BASE_URL=https://llm.example.com
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# === Docker deployment ===
# When NanoClaw runs inside a container, set this to the host-side path where
# the compose project lives. Agent containers (spawned via the Docker socket)
# need host paths for their bind mounts.
# HOST_PROJECT_DIR=/opt/nanoclaw
# Agent container image (default: nanoclaw-agent:latest)
# CONTAINER_IMAGE=cr.guneet.xyz/nanoclaw/agent:latest

# === Optional ===
TZ=UTC
# CONTAINER_TIMEOUT=1800000
# IDLE_TIMEOUT=1800000
# MAX_CONCURRENT_CONTAINERS=5
# MAX_MESSAGES_PER_PROMPT=10
# LOG_LEVEL=info
